/**approval-result.wxss**/
page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  background-color: #f5f5f5;
}

.scrollarea {
  flex: 1;
  overflow-y: auto;
}

.app {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  background-color: white;
}

.page {
  width: 100%;
  max-width: 500px;
  min-height: 100vh;
  position: relative;
  padding: 20rpx;
  box-sizing: border-box;
}

/* 步骤条样式 */
.steps {
  display: flex;
  justify-content: space-between;
  padding-top: 20%;
  margin-bottom: 30px;
  padding: 0 20rpx;
}

.step-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.step-circle {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background-color: #c0c4cc;
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
  font-size: 28rpx;
}

.step-item.active .step-circle {
  background-color: #67c23a;
}

.step-title {
  font-size: 24rpx;
  color: #909399;
  text-align: center;
}

.step-item.active .step-title {
  color: #67c23a;
}

/* 分割线样式 */
.divider {
  height: 1px;
  background-color: #e4e7ed;
  position: relative;
  margin: 40rpx 0;
  text-align: center;
}

.divider text {
  position: relative;
  top: -20rpx;
  background-color: white;
  padding: 0 40rpx;
  font-size: 28rpx;
}

/* 滚动消息样式 */
.roll-container {
  transition: all 0.5s ease;
}

.item {
  color: #FFF;
  background-color: red;
  margin-top: 20rpx;
  border-radius: 8rpx;
  height: 68rpx;
  line-height: 68rpx;
  width: 100%;
  font-size: 28rpx;
}

/* 滚动动画 */
@keyframes roll {
  0% {
    transform: translateY(0);
  }
  100% {
    transform: translateY(-68rpx);
  }
}

.roll-container {
  animation: roll 0.5s ease-out;
}
