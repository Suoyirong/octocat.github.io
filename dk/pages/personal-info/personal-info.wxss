/**personal-info.wxss**/
page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  background-color: #f5f5f5;
}

.scrollarea {
  flex: 1;
  overflow-y: auto;
}

.app {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  background-color: white;
}

.page {
  width: 100%;
  max-width: 500px;
  min-height: 100vh;
  position: relative;
  padding: 20rpx;
  box-sizing: border-box;
}

/* 输入框样式 */
.input {
  width: 100%;
  height: 80rpx;
  border: 1px solid #dcdfe6;
  border-radius: 8rpx;
  padding: 0 30rpx;
  box-sizing: border-box;
  font-size: 32rpx;
  background-color: white;
}

/* 底部按钮样式 */
.bottom-btn {
  position: fixed;
  bottom: 0;
  left: 0;

  height: 100rpx;
  background-color: #409eff;
  color: white;
  border: none;
  border-radius: 0;
  font-size: 36rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
      width: 100vw;
}
